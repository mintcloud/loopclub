# loopclub X growth bot — credentials
# Copy to ~/.config/loopclub/x-bot.env, chmod 600, then fill in real values.
# Get these from the X Developer Portal (developer.x.com) for the @loopclub app:
#   User authentication settings -> OAuth 1.0a, "Read and write" permissions
#   Keys and tokens -> API Key & Secret, then Access Token & Secret (generate
#   the access token AFTER setting Read+Write, or regenerate it if the app
#   permissions changed after the token already existed).

LOOPCLUB_X_API_KEY=
LOOPCLUB_X_API_SECRET=
LOOPCLUB_X_ACCESS_TOKEN=
LOOPCLUB_X_ACCESS_SECRET=
