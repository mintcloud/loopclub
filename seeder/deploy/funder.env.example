# loopclub funder config — copy to ~/.config/loopclub/funder.env, chmod 600.
# Read by loopclub-funder.service via EnvironmentFile. Two secrets matter: the
# OWNER key (the only key allowed to sweep the contract) and the seeder's
# PUBLIC address (the top-up destination — no seeder private key needed here).

# ── Required ──
# Contract-owner wallet. ONLY this key can call sweepUnattributed(). This is the
# Loopclub deployer/owner key, NOT the seeder key. 32-byte hex (with/without 0x).
OWNER_PRIVATE_KEY=0xCHANGE_ME
# Public address of the seeder wallet to top up (the SEEDER_PRIVATE_KEY's address).
SEEDER_ADDRESS=0xCHANGE_ME

# ── Chain (defaults shown — fine for MegaETH mainnet) ──
RPC_URL=https://mainnet.megaeth.com/rpc
CHAIN_ID=4326
LOOPCLUB_ADDRESS=0x1030D1a60e248E280294d1b04394f706904E3631
PAYMENT_TOKEN_ADDRESS=0xFAfDdbb3FC7688494971a79cc65DCa3EF82079E7

# ── Top-up policy (whole or decimal USDm) ──
# Refill only when the seeder balance drops below this low watermark…
FUND_LOW_USDM=10
# …and then sweep enough to bring it back up to this target.
FUND_TARGET_USDM=50
# Never send a tx for less than this (skips dust top-ups, saves gas).
FUND_MIN_SWEEP_USDM=1
# Extra USDm to always leave behind in the contract, on top of the royalty
# reserve. Cheap insurance against rounding / event-scan lag. 0 = off.
FUND_RESERVE_BUFFER_USDM=0

# ── Royalty-reserve scan (advanced; defaults are correct for mainnet) ──
# Contract deploy block — where the incremental royalty-event scan begins.
FUND_DEPLOY_BLOCK=17164882
# getLogs window size; keep under the RPC's block-range cap.
FUND_LOG_CHUNK=45000
# Cursor + running royalty totals cache. Must be under a writable path (the
# service grants ReadWritePaths=~/.config/loopclub).
FUND_STATE_PATH=/home/theo/.config/loopclub/funder-state.json

# DRY_RUN=true computes and logs the sweep decision but sends no tx — use it for
# the first run to confirm the numbers before letting it move money.
DRY_RUN=false
