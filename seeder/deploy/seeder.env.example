# loopclub seeder config — copy to ~/.config/loopclub/seeder.env, chmod 600.
# Read by the systemd unit via EnvironmentFile. The private key is the only
# secret; everything else has a sane default and can be omitted.

# ── Required ──
# Custodial wallet that holds USDm and signs toggle()/approve(). Fund it with a
# few USDm before flipping the bot on. 32-byte hex (with or without 0x).
SEEDER_PRIVATE_KEY=0xCHANGE_ME

# ── Chain (defaults shown — fine for MegaETH mainnet) ──
RPC_URL=https://mainnet.megaeth.com/rpc
# Optional WebSocket RPC: when set, CellRented arrives via eth_subscribe push
# instead of a 1s getLogs poll. Leave blank to poll.
WS_RPC_URL=
CHAIN_ID=4326
LOOPCLUB_ADDRESS=0x1030D1a60e248E280294d1b04394f706904E3631
PAYMENT_TOKEN_ADDRESS=0xFAfDdbb3FC7688494971a79cc65DCa3EF82079E7

# ── Presence collector ──
PRESENCE_PORT=3009
PRESENCE_BIND=127.0.0.1
# Origins allowed to beat — comma-separated, checked server-side and 403'd. A
# beat makes the bot spend, so this is a spend gate, not a CORS nicety: setting
# the header without checking it stops nobody (a forger doesn't use a browser).
# `*` disables the check and lets any page on the web make robodj play.
PRESENCE_ALLOW_ORIGIN=https://app.loopclub.xyz
# A session counts as "active" if seen within this window (ms). This is the
# hysteresis: a 15s frontend re-beat sits well under 30s, so the count never
# flickers; a closed tab drops off within 30s.
PRESENCE_TTL_MS=30000
# Per-IP ceilings (keyed on CF-Connecting-IP), so one host can't fake a crowd.
# A real tab beats 4×/min — these are loose by design.
PRESENCE_MAX_BEATS_PER_MIN=40
PRESENCE_MAX_SESSIONS_PER_IP=8

# Where the rent caps keep their books. The caps are the seeder's ONLY real
# ceiling — the funder refills the wallet, so its balance is a faucet, not a
# fence — and the unit is Restart=always, so in-memory windows meant every bounce
# forgave the hour. This file makes them a budget. Must be inside the unit's
# ReadWritePaths. DRY_RUN never writes it.
RENT_STATE_PATH=/home/<user>/.config/loopclub/rent-state.json

# ── Jam control (defaults shown) ──
TICK_MS=3000
CELLS_PER_GROOVE=6
RENT_LOOPS=8
RENEW_THRESHOLD_LOOPS=3
# How long one groove stays on the grid before the bot rotates to the next.
GROOVE_HOLD_MS=30000

# ── The rotation ──
# What the bot rotates through:
#   genres  — the procedural templates only (house, boom-bap, techno, dnb)
#   setlist — the hand-authored tunes only (Seven Nation Army, Ode to Joy,
#             La Marseillaise, Olé Olé Olé, Thunder Clap, Batucada, We Will Rock You)
#   mixed   — both, interleaved (default)
POOL=mixed
# Cell budget for a setlist groove. Bigger than CELLS_PER_GROOVE because a tune
# needs its melody — trimmed to 6 cells, Seven Nation Army is just noise. Drums
# are dropped before synth notes when this bites (a 2-cell pulse is kept back).
# Cost scales linearly with this: see the rent-cap note below.
SETLIST_CELLS=14
# Your own loops, added to the rotation: comma-separated `?jam=` deep links, the
# ones the MCP `build_loop` tool hands back. Malformed links are logged + skipped.
# SETLIST_LINKS=https://app.loopclub.xyz/?jam=AQEBAAAQ...,https://app.loopclub.xyz/?jam=AQUFAAAQ...
SETLIST_LINKS=

# ── Safety / rollout ──
# THE COST MODEL, because it is not obvious: rent is charged per cell per loop, so
# a lit cell costs rentPerLoop (0.004 USDm) every 4s loop = 0.001 USDm/second. The
# bot's burn is therefore (cells lit × seconds held), and NOTHING else — renting
# for longer is not cheaper, it just pays further ahead. In round numbers, per
# hour of continuous jamming: a 6-cell genre groove ≈ 22 USDm, a 14-cell tune ≈ 50
# USDm. The bot only jams while a visitor is present and no human holds a cell, so
# real spend is a fraction of that — but on a busy day the fraction is not small.
#
# SIZE THESE AGAINST THE BOT'S BURN RATE, NOT THE WALLET BALANCE. The rent the
# bot pays is not lost: toggle() moves USDm into the contract and never routes it
# onward (Loopclub.sol), so it lands in the unattributed slice that the funder
# sweeps straight back into this wallet. Seeder → contract → funder → seeder is a
# closed loop; the only true outflows are gas (negligible on MegaETH) and royalties
# on secondary sales. Cap the wallet as if the USDm were spent and you strangle the
# bot: an 8 USDm/hour cap buys ~10 minutes of a 14-cell tune, after which robodj
# sits out the other 50 minutes with a full wallet.
#
# So set the caps ABOVE continuous-jam burn — they exist to stop runaway logic
# (a bug renting 100 cells a tick), not to protect solvency. 60/hour clears the
# 50 USDm/hour worst case (a 14-cell tune held nonstop) with headroom.
HOURLY_RENT_CAP_USDM=60
# Hard ceiling on USDm spent per UTC day (whole USDm). 0 = unlimited. 400 ≈ 11
# hours of continuous jamming — a backstop, not a budget.
# Both windows are in-memory: a restart forgives the spend so far. They are a
# brake on runaway logic, not an accounting ledger.
DAILY_RENT_CAP_USDM=400
# DRY_RUN=true runs the full control loop but logs toggles instead of sending
# them — use it to watch the state machine against the real grid with no spend.
DRY_RUN=false
# FORCE_ACTIVE=true bypasses the presence collector and always behaves as if one
# visitor is present. Build-order step 1 ONLY — proves the on-chain behaviour
# before the frontend heartbeat exists. NEVER leave on in production.
FORCE_ACTIVE=false

# ── Requests ("play X next") ──
# Off by default. When on, the presence collector also serves GET /repertoire and
# POST /request, and the bot serves the queue before its own rotation.
REQUESTS_ENABLED=false
# THE knob. Cost is `cells x rentPerLoop x rentLoops`, so this — not the person
# asking — decides what a request can cost. A request names a groove off the
# repertoire; it never carries a spec. If that ever changes, this is the only
# thing standing between a stranger's "wall of sound" and 24x the rent.
REQUEST_CELLS=14
REQUEST_QUEUE_MAX=8
REQUEST_COOLDOWN_MS=60000
REQUEST_TTL_MS=120000

# ── The brain ──
# Unset → loopgen renders grooves in-process (no network).
# Set    → the groove is rendered by calling `build_loop` on this MCP server, and
#          the bot plays what comes back. That makes the MCP call a chokepoint: a
#          proxy in front of it (a gateway, a policy engine, an audit log) can see
#          and price the spend before any toggle() is signed. It fails CLOSED — if
#          the call errors, that groove is not played. A chokepoint you can bypass
#          by knocking it over is not a chokepoint.
#
#          Point this at a gateway (e.g. TrustGate) instead of the MCP server and
#          robodj's code does not change by one line.
# MCP_URL=https://mcp.tg-itsavibe.com/mcp
MCP_TIMEOUT_MS=10000

# WHICH grooves take that path. This is the knob that makes a gateway safe to
# deploy — and safe to TEAR DOWN.
#
#   requests (default) — only a visitor's request is rendered over MCP. The idle
#                        pulse always renders locally. The gateway therefore
#                        governs exactly the surface whose arguments came from
#                        outside, and robodj's autonomous cell-filling NEVER
#                        depends on it. Kill the gateway: the pulse plays on,
#                        requests stop being served. That is the correct thing to
#                        lose when the policy plane is gone.
#   all                — the idle pulse goes through MCP too, so 100% of the bot's
#                        spend crosses the proxy. Purer to measure and the mode to
#                        run while capturing a gateway demo. The price is real:
#                        the brain fails closed, so a gateway outage now means
#                        SILENCE. Do not leave this on unattended.
#
# Routing by origin is not a bypass — a stranger cannot turn their request into an
# idle pulse. Falling back to the local renderer ON ERROR would be, and the brain
# never does that in either scope.
MCP_SCOPE=requests
