{
  "name": "loopclub-mcp",
  "version": "0.1.0",
  "description": "Jam with Claude — an MCP server that turns a described beat into a loopclub link, ready to audition and rent on-chain. A pure encoder over loopgen; holds no keys, signs nothing.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "loopclub-mcp": "dist/index.js",
    "loopclub-mcp-http": "dist/http.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "loopclub-loopgen": "file:../loopgen",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
