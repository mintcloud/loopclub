{
  "name": "loopclub-mcp",
  "version": "0.1.0",
  "description": "Jam with Claude — an MCP server that turns a described beat into a loopclub link, ready to audition and rent on-chain. A pure encoder over loopgen; holds no keys, signs nothing.",
  "license": "Apache-2.0",
  "type": "module",
  "mcpName": "io.github.mintcloud/loopclub",
  "homepage": "https://loopclub.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mintcloud/loopclub.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/mintcloud/loopclub/issues"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "music",
    "drum-machine",
    "step-sequencer",
    "loopclub",
    "claude"
  ],
  "bin": {
    "loopclub-mcp": "dist/index.js",
    "loopclub-mcp-http": "dist/http.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:publish": "rm -rf dist && esbuild src/index.ts src/http.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist --external:@modelcontextprotocol/sdk --external:zod",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build:publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.2",
    "loopclub-loopgen": "file:../loopgen",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
