# ───── Wallet backend ─────
# Which embedded wallet the app uses. 'privy' (default) keeps the original
# Privy smart-wallet + ZeroDev stack; 'moss' uses MegaETH's MOSS wallet
# (@megaeth-labs/wallet-sdk-react). Build-time only — set it and redeploy.
VITE_WALLET_PROVIDER=privy
# MOSS-only: which MegaETH network MOSS connects to. loopclub is on mainnet.
VITE_MOSS_NETWORK=mainnet
# MOSS-only: gas payment model.
#   false (default) → users pay their own gas (ETH or USDm/USDT0 from their MOSS
#                     balance). This is guaranteed user-pays — nothing is sponsored.
#   true            → the app sponsors gas (gasless one-tap). ALSO requires
#                     VITE_MOSS_SPONSOR_URL below; without it nothing is sponsored
#                     and users still pay.
VITE_MOSS_SPONSOR=false
# MOSS-only: your sponsor backend endpoint (MOSS calls it to approve/fund each
# sponsored op). Needed only when VITE_MOSS_SPONSOR=true. Leave blank for user-paid.
VITE_MOSS_SPONSOR_URL=

# Required only when VITE_WALLET_PROVIDER=privy:
VITE_PRIVY_APP_ID=
VITE_CHAIN_ID=4326
VITE_RPC_URL=https://mainnet.megaeth.com/rpc
# Optional WebSocket RPC. When set, the live grid pushes cell rentals over
# eth_subscribe instead of polling getLogs. Confirm the endpoint with MegaETH
# docs before setting it; leaving it blank falls back to a 1s getLogs poll.
VITE_WS_RPC_URL=
VITE_LOOPCLUB_ADDRESS=0x1030D1a60e248E280294d1b04394f706904E3631
VITE_PAYMENT_TOKEN_ADDRESS=0xFAfDdbb3FC7688494971a79cc65DCa3EF82079E7
VITE_EXPLORER_URL=https://megaeth.blockscout.com

# ───── Fast mode / session keys (Step 4) ─────
# ZeroDev bundler + paymaster RPC. Same project the Privy Kernel wallet uses
# (the project id is visible in any UserOp request in the network tab).
VITE_ZERODEV_RPC_URL=https://rpc.zerodev.app/api/v3/8d4668f3-c808-4bd7-8731-6aad2c0c4817/chain/4326
# Master switch for session keys. Keep this `false` until you've verified it in
# a preview deploy: open the console, click "enable fast mode", and confirm the
# `[sessionKey] kernel address matches ✓` line. Then set it `true` in prod.
# Safe by construction even when `true` — a kernel-address mismatch disables
# fast mode and falls back to the Privy signing path; funds can't be misrouted.
VITE_ENABLE_SESSION_KEYS=false
